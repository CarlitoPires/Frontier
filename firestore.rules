rules_version = '2';

// LinguoBound — Firestore Security Rules
// Real enforcement layer (client-side checks are UX only).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    // Admin = custom claim { admin: true } (set via Admin SDK / CLI),
    // OR a users/{uid} doc with role == 'admin' (no-key bootstrap path).
    // Note: get()/exists() in rules bypass rules themselves (no recursion).
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    // A user can read/update only their own profile.
    // 'plan', 'role' and 'subscription' are server-controlled: clients
    // must NOT be able to promote themselves to pro/admin.
    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role == 'user'
                    && request.resource.data.plan == 'free';
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == uid
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.plan == resource.data.plan
                        && request.resource.data.subscription == resource.data.subscription);
      allow delete: if isAdmin();
    }

    // ---------- Hard Gate helpers ----------
    function passThreshold() { return 80; }

    function moduleFieldsValid(d) {
      return d.keys().hasAll(['sequence', 'status', 'score'])
        && d.keys().hasOnly(['sequence', 'status', 'score', 'attempts', 'updatedAt', 'passedAt', 'blockId', 'title', 'accuracy', 'patienceEnd', 'retries', 'mode'])
        && d.sequence is int && d.sequence >= 1 && d.sequence <= 500
        && d.score is int && d.score >= 0 && d.score <= 100
        && (d.status == 'ATTEMPTED' || d.status == 'PROFICIENCY_PASSED');
    }

    // Module N is reachable only if N == 1, or module N-1 is already passed.
    // get()/exists() bypass rules (no recursion) and read committed state,
    // so a client cannot forge its way down the chain.
    function predecessorPassed(uid, seq) {
      return seq == 1
        || (
          exists(/databases/$(database)/documents/progress/$(uid)/modules/$(string(seq - 1)))
          && get(/databases/$(database)/documents/progress/$(uid)/modules/$(string(seq - 1))).data.status == 'PROFICIENCY_PASSED'
        );
    }

    // Per-user progression — the authoritative Hard Gate lives here.
    match /progress/{uid} {
      // Display cache (non-authoritative): owner-managed summary + streak + aggregates.
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create, update: if isSignedIn() && request.auth.uid == uid
        && (!('unlockedSequence' in request.resource.data)
            || (request.resource.data.unlockedSequence is int && request.resource.data.unlockedSequence >= 1));
      allow delete: if false;

      match /modules/{moduleId} {
        allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);

        // The gate: owner-only; doc-id must equal the sequence; you may only
        // touch a module whose predecessor you've passed; and you may only
        // claim PROFICIENCY_PASSED with a score >= threshold. A passed module
        // can never be regressed to a lower status.
        allow create, update: if isSignedIn() && request.auth.uid == uid
          && moduleFieldsValid(request.resource.data)
          && request.resource.data.sequence == int(moduleId)
          && predecessorPassed(uid, request.resource.data.sequence)
          && (
            request.resource.data.status == 'ATTEMPTED'
            || (request.resource.data.status == 'PROFICIENCY_PASSED'
                && request.resource.data.score >= passThreshold())
          )
          && (
            resource == null
            || resource.data.status != 'PROFICIENCY_PASSED'
            || request.resource.data.status == 'PROFICIENCY_PASSED'
          );
        allow delete: if false;
      }
    }

    // Aggregated metrics powering the admin command center.
    match /metrics/{doc} {
      allow read: if isAdmin();
      allow write: if false; // written by Cloud Functions / batch jobs
    }

    // Public code -> uid lookup so an invitee can resolve who invited them.
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Referrals (viral loop): the invitee records who invited them; the
    // inviter can query their own referrals to count them.
    match /referrals/{inviteeUid} {
      allow read: if isAdmin()
        || (isSignedIn() && (request.auth.uid == inviteeUid || resource.data.inviterUid == request.auth.uid));
      allow create: if isSignedIn() && request.auth.uid == inviteeUid
        && request.resource.data.inviterUid is string
        && request.resource.data.inviterUid != request.auth.uid;   // no self-referral
      allow update, delete: if false;
    }

    // Content tree (cities -> blocks -> modules) is public-readable.
    match /content/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
